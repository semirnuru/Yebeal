{
  "name": "yebeal-borsa-backend",
  "version": "1.0.0",
  "description": "Yebeal Borsa - Backend API Server",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "db:generate": "npx prisma generate",
    "db:push": "npx prisma db push",
    "db:migrate": "npx prisma migrate dev",
    "db:seed": "node prisma/seed.js",
    "db:reset": "npx prisma migrate reset --force && node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "6.9.0",
    "@supabase/supabase-js": "2.107.0",
    "bcryptjs": "3.0.2",
    "cookie-parser": "1.4.7",
    "cors": "2.8.5",
    "dotenv": "16.5.0",
    "express": "5.1.0",
    "express-rate-limit": "7.5.1",
    "helmet": "8.1.0",
    "ioredis": "5.6.1",
    "jsonwebtoken": "9.0.2",
    "multer": "2.1.1",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "rate-limit-redis": "4.2.0",
    "winston": "3.17.0",
    "zod": "4.4.3",
    "zod-validation-error": "5.0.0"
  },
  "devDependencies": {
    "prisma": "6.9.0"
  }
}