# Database
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/yebeal_borsa?schema=public"

# JWT — CHANGE THIS to a long random string in production!
JWT_SECRET="change-this-to-a-very-long-random-secret-key-in-production"
JWT_EXPIRES_IN="7d"

# Server
PORT=3001
NODE_ENV=production

# CORS — Set to your production frontend URL
FRONTEND_URL="https://yourdomain.com"
